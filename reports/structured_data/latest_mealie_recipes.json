    {
      "name": "Tarte Tatin aux Pommes",
      "slug": "tarte-tatin-aux-pommes",
      "description": "Dessert classique français renversé avec pommes caramélisées",
      "prep_time": "15",
      "cook_time": "20",
      "total_time": "35",
      "servings": "8",
      "ingredients": [
        "1kg de pommes fermes (Golden ou Reinette)",
        "200g de sucre semoule",
        "100g de beurre doux",
        "1 pâte brisée",
        "1 cuillère à café de cannelle",
        "1 gousse de vanille",
        "Crème glacée vanille pour servir"
      ],
      "instructions": [
        {
          "text": "Préchauffer le four à 180°C (Thermostat 6)",
          "title": "Étape 1"
        },
        {
          "text": "Peler les pommes et les couper en quartiers",
          "title": "Étape 2"
        },
        {
          "text": "Faire fondre le sucre dans une poêle jusqu'à obtention d'un caramel blond",
          "title": "Étape 3"
        }
      ],
      "source_url": "https://www.marmiton.org/recettes/recette_tarte-tatin-aux-pommes_12345.aspx",
