# Mealie Configuration
MEALIE_BASE_URL=http://localhost:9925
MEALIE_API_KEY=your-mealie-api-key
MEALIE_PORT=9925
MEALIE_ADMIN_EMAIL=admin@example.com
MEALIE_ADMIN_PASSWORD=changeme

# AI Configuration (OpenAI)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# AI Configuration (Anthropic - optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-haiku-20240307

# AI Configuration (Mistral - optional)
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest

# Nutrition Addon Configuration
AI_PROVIDER=mock
USE_AI_ESTIMATION=false
OFF_BASE_URL=https://world.openfoodfacts.org
NUTRITION_CACHE_TTL_DAYS=30

# Addon API Configuration
ADDON_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# Port Configuration
IMPORT_API_PORT=8000
IMPORT_UI_PORT=8501
NUTRITION_API_PORT=8001
BUDGET_API_PORT=8003
BUDGET_UI_PORT=8503

# Budget Addon Configuration
OPEN_PRICES_BASE_URL=https://prices.openfoodfacts.org/api/v1
ENABLE_OPEN_PRICES=true
ENABLE_MANUAL_PRICES=true
ENABLE_BUDGET_PLANNING=true
NUTRITION_API_URL=

# Rafraîchissement mensuel des coûts dans Mealie (extras.cout_*)
# Cron 5-champs UTC: minute heure jour mois jour-semaine (défaut: 1er du mois 03:00)
ENABLE_MONTHLY_COST_REFRESH=true
MONTHLY_COST_REFRESH_CRON=0 3 1 * *
