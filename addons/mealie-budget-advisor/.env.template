# Mealie (obligatoire - instance Coolify séparée)
MEALIE_BASE_URL=https://your-mealie-instance.example.com
MEALIE_API_KEY=your-mealie-api-key

# Open Prices (pas de clé API requise pour GET)
OPEN_PRICES_BASE_URL=https://prices.openfoodfacts.org/api/v1

# API Server
ADDON_API_HOST=0.0.0.0
ADDON_API_PORT=8003
ADDON_SECRET_KEY=change-me-in-production

# UI Server
ADDON_UI_PORT=8503
ADDON_API_URL=https://your-budget-api-instance.example.com

# Feature Flags
ENABLE_OPEN_PRICES=true
ENABLE_MANUAL_PRICES=true
ENABLE_BUDGET_PLANNING=true

# Rafraîchissement mensuel des coûts (publie dans extras.cout_* de chaque recette Mealie).
# Préserve toujours les clés cout_manuel_* posées manuellement dans Mealie.
ENABLE_MONTHLY_COST_REFRESH=true
# Expression cron 5 champs (UTC) — défaut: 1er du mois à 03:00
MONTHLY_COST_REFRESH_CRON=0 3 1 * *

# AI Provider (optionnel, pour génération de données)
# Utilisé uniquement pour générer la base de poids moyens (une seule fois)
AI_PROVIDER=openai  # openai, anthropic, etc.
AI_API_KEY=your-ai-api-key
AI_MODEL=gpt-4o-mini

# Logs
LOG_LEVEL=INFO
