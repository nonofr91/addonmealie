      "recipeInstructions": [
        {
          "id": "1b0e3d4e-aaaa-bbbb-cccc-000000000001",
          "title": "Préparation des œufs",
          "summary": "",
          "text": "Battre les jaunes d'œufs en y ajoutant 1 pincée de sel, 2 pincées de poivre et 40 g de parmigiano reggiano râpé.",
          "ingredientReferences": []
        },
        {
          "id": "1b0e3d4e-aaaa-bbbb-cccc-000000000002",
          "title": "Cuisson de l'eau",
          "summary": "",
          "text": "Remplir une grande casserole d'eau et la faire chauffer avec deux pincées de gros sel.",
          "ingredientReferences": []
        },
        {
          "id": "1b0e3d4e-aaaa-bbbb-cccc-000000000003",
          "title": "Cuisson de la pancetta",
          "summary": "",
          "text": "Pendant ce temps, couper la pancetta en lamelles grossières et les faire dorer dans une poêle avec 1 cuillère à soupe d'huile d'olive.",
          "ingredientReferences": []
        },
        {
          "id": "1b0e3d4e-aaaa-bbbb-cccc-000000000004",
          "title": "Cuisson des pâtes",
          "summary": "",
          "text": "Quand l'eau dans la casserole commence à bouillir, mettez vos pâtes.",
          "ingredientReferences": []
        },
        {
          "id": "1b0e3d4e-aaaa-bbbb-cccc-000000000005",
          "title": "Préparation de la sauce",
          "summary": "",
          "text": "Prendre deux cuillères à soupe d'eau de cuisson des pâtes, les verser dans les jaunes d'œufs puis remuer.",
          "ingredientReferences": []
        },
        {
          "id": "1b0e3d4e-aaaa-bbbb-cccc-000000000006",
          "title": "Mélange pâtes-pancetta",
          "summary": "",
          "text": "Réservez la pancetta et laissez la poêle au chaud. Une fois la cuisson des pâtes al dente, les égoutter sommairement et les mettre dans la poêle et remuer.",
          "ingredientReferences": []
        },
        {
          "id": "1b0e3d4e-aaaa-bbbb-cccc-000000000007",
          "title": "Incorporation de la sauce",
          "summary": "",
          "text": "Verser le mélange dans un saladier et incorporez la préparation des jaunes d'œufs.",
          "ingredientReferences": []
        },
        {
          "id": "1b0e3d4e-aaaa-bbbb-cccc-000000000008",
          "title": "Finition",
          "summary": "",
          "text": "Ajouter la pancetta et deux pincées de poivre. Servez.",
          "ingredientReferences": []
        }
      ],
