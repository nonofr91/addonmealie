      "recipeInstructions": [
        {
          "id": "8114eb5d-a529-41d4-a1cc-86cc55bb0020",
          "title": "Étape 1",
          "summary": "",
          "text": "Rincer les lentilles.",
          "ingredientReferences": []
        },
        {
          "id": "c8abbc12-87db-4f34-b356-1de83a251d93",
          "title": "Étape 2",
          "summary": "",
          "text": "Dans une sauteuse profonde, faire revenir le lard coupé en petits morceaux.",
          "ingredientReferences": []
        },
        {
          "id": "89daefec-1b27-4c76-a65f-f83c511669c9",
          "title": "Étape 3",
          "summary": "",
          "text": "Une fois que le lard est doré, ajoutez les lentilles, l'estragon et poivrez.",
          "ingredientReferences": []
        },
        {
          "id": "86280ee2-c343-45a5-a2ae-a0072fbada6c",
          "title": "Étape 4",
          "summary": "",
          "text": "Couvrez d'eau et laissez cuire 1/2 heure.",
          "ingredientReferences": []
        },
        {
          "id": "2f2a015d-d805-4e6b-a270-d04e357ba769",
          "title": "Étape 5",
          "summary": "",
          "text": "5 minutes avant la fin de la cuisson, faites revenir la pomme coupée en petits morceaux dans une poêle avec la cuiller à soupe de margarine et la cuiller à soupe de miel.",
          "ingredientReferences": []
        },
        {
          "id": "4080ba12-bb99-4aa1-a126-709cf49d079a",
          "title": "Étape 6",
          "summary": "",
          "text": "Attendez qu'elle soit dorée.",
          "ingredientReferences": []
        },
        {
          "id": "5da6b4da-dc95-4704-8292-f0ce37793103",
          "title": "Étape 7",
          "summary": "",
          "text": "Vérifiez les lentilles et éliminez si nécessaire le jus excédentaire.",
          "ingredientReferences": []
        },
        {
          "id": "b0003752-9542-4e98-8a88-d809c4484ecb",
          "title": "Étape 8",
          "summary": "",
          "text": "Ajoutez la pomme.",
          "ingredientReferences": []
        },
        {
          "id": "144787d5-689a-4324-93f2-75a993ad2813",
          "title": "Étape 9",
          "summary": "",
          "text": "Parfumez d'un peu de vinaigre de cidre.",
          "ingredientReferences": []
        },
        {
          "id": "7ac0f4cc-b60a-42fa-8af6-bd195fc9220f",
          "title": "Étape 10",
          "summary": "",
          "text": "Laissez refroidir.",
          "ingredientReferences": []
        },
        {
          "id": "3a421852-35e7-4bef-b6f1-54a144c11ca9",
          "title": "Étape 11",
          "summary": "",
          "text": "A consommer comme une salade.",
          "ingredientReferences": []
        },
        {
          "id": "2430cb69-bc94-443a-8ded-7d6f8d5f275b",
          "title": "Étape 12",
          "summary": "",
          "text": "Voilà un plat aux saveurs parfumées, nutritif et équilibré, facile à préparer et peu coûteux!",
          "ingredientReferences": []
        }
      ],
