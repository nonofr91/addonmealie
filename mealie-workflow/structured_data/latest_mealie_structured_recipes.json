      "recipeInstructions": [
        {
          "id": "ffd86dc1-c08f-4857-9df6-305aee5cea2c",
          "title": "Étape 1",
          "summary": "",
          "text": "Dans un grand plat allant au four, mettre le beurre coupé en morceaux, poser les branches de thym et de laurier.",
          "ingredientReferences": []
        },
        {
          "id": "02159821-8b1f-4492-93c3-4d4d34df08eb",
          "title": "Étape 2",
          "summary": "",
          "text": "Tartiner les filets mignons de moutarde (sur tous les côtés), les poser dans le plat sur les branches de thym et laurier.",
          "ingredientReferences": []
        },
        {
          "id": "a924d018-bb95-42b8-aa9b-ed50efbee28e",
          "title": "Étape 3",
          "summary": "",
          "text": "Saler et poivrer et mettre au four préchauffé à 210°C pendant 45 mn (retourner à mi-cuisson).",
          "ingredientReferences": []
        },
        {
          "id": "23be9052-0a12-48b8-b89e-d06dd0e76255",
          "title": "Étape 4",
          "summary": "",
          "text": "Pendant ce temps, éplucher les pommes de terre (les couper si elles sont grosses).",
          "ingredientReferences": []
        },
        {
          "id": "00021278-6e94-4175-82be-27b18af72faf",
          "title": "Étape 5",
          "summary": "",
          "text": "Faire cuire les pommes de terre à la vapeur.",
          "ingredientReferences": []
        },
        {
          "id": "4e74643b-458f-40f4-8828-33f34e9f72fe",
          "title": "Étape 6",
          "summary": "",
          "text": "Sortir le plat du four, retourner les filets mignons, ajouter 1 grand verre d'eau pour délayer la sauce, mettre les pommes de terre autour des filets mignons. Enfourner de nouveau pour environ 30 mn.",
          "ingredientReferences": []
        },
        {
          "id": "d170dfb4-8033-47fd-b147-b22574b87cbb",
          "title": "Étape 7",
          "summary": "",
          "text": "Bon appétit !",
          "ingredientReferences": []
        }
      ],
