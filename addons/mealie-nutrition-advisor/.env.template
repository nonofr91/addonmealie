# Mealie (obligatoire - instance Coolify séparée)
MEALIE_BASE_URL=https://your-mealie-instance.example.com
MEALIE_API_KEY=your-mealie-api-key

# IA – fallback nutritionnel (optionnel)
# Utilisé quand Open Food Facts ne trouve pas un ingrédient.
# Options : openai | anthropic | mistral | mock (défaut: mock — aucune clé requise)
AI_PROVIDER=mock
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-small-latest

# IA – estimation des quantités (optionnel)
# Utiliser l'estimation IA pour les ingrédients sans poids explicite.
# Options : true | false (défaut: false)
USE_AI_ESTIMATION=false

# Open Food Facts
OFF_BASE_URL=https://world.openfoodfacts.org/api/v2
NUTRITION_CACHE_TTL_DAYS=30
USDA_API_KEY=

# API Server (optionnel)
ADDON_API_HOST=0.0.0.0
ADDON_API_PORT=8001
ADDON_SECRET_KEY=your-secret-key-here

# UI Server (optionnel)
ADDON_UI_PORT=8502
ADDON_API_URL=https://your-nutrition-api-instance.example.com

# Logs
LOG_LEVEL=INFO

# Feature Flags
# Permet d'activer/désactiver des fonctionnalités spécifiques
ENABLE_PROFILE_UI=true
ENABLE_MENU_PLANNER=true
ENABLE_NUTRITION_ANALYSIS=true
ENABLE_CONFLICT_DETECTION=true

# Menu Planning Enhancement Flags
ENABLE_MENU_PLANNING_UI=true
ENABLE_SEASONALITY=true
ENABLE_VARIETY_SCORING=true
