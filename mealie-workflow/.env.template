# Mealie Workflow Configuration
# Variables d'environnement pour le workflow Mealie

# AI Provider Configuration
# Pour le développement local : utiliser "cascade" (par défaut)
# Pour la production Coolify : utiliser "openai" ou "anthropic"
AI_PROVIDER=cascade

# Configuration OpenAI (si AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# Configuration Anthropic (si AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-opus

# Configuration Mealie (pour les addons qui utilisent Mealie)
MEALIE_BASE_URL=http://localhost:9925/api
MEALIE_API_KEY=your-mealie-api-key

# Log level
LOG_LEVEL=INFO
