# Mealie (obligatoire - instance Coolify séparée)
MEALIE_BASE_URL=https://your-mealie-instance.example.com
MEALIE_API_KEY=your-mealie-api-key

# IA – optionnel (fallback JSON-LD si absent)
AI_PROVIDER=mistral
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-small-latest

# Addon
# Clé d'accès à l'API REST (laisser vide pour dev local)
ADDON_SECRET_KEY=change-me-in-production

ADDON_API_PORT=8000
ADDON_UI_PORT=8501
LOG_LEVEL=INFO

# Feature Flags
ENABLE_NUTRITION=true
ENABLE_INGREDIENT_MANAGER=true
ENABLE_IMAGE_MANAGER=true
INGREDIENT_AI_PROVIDER=mistral
IMAGE_AI_PROVIDER=mistral
